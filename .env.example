# Cole aqui a URL que o Railway gera para o seu banco PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/mavifit"

# Troque por uma string aleatória longa (ex: gerada em https://randomkeygen.com)
JWT_SECRET="troque-por-uma-string-secreta-longa"

# Porta do servidor (Railway define automaticamente)
PORT=3000

# Cloudinary (para armazenar as fotos) — crie conta gratuita em cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
